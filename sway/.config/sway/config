### Autostart setup
exec --no-startup-id mako
exec --no-startup-id picom -b
exec --no-startup-id synology-drive
exec --no-startup-id udiskie --smart-tray
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id code-insiders
exec --no-startup-id chromium
exec --no-startup-id bitwarden-desktop
for_window [class="Bitwarden"] sticky enable border none
for_window [class="Bitwarden"] move scratchpad

# Few little adds
default_orientation auto
workspace_auto_back_and_forth yes
popup_during_fullscreen smart
focus_wrapping yes
force_display_urgency_hint 500 ms

# Font for Windows titles and bar, unless otherwise specified
font pango:Overpass Mono 12

# Import theme first so invidual modifications can be made
include ~/.config/sway/themes/gruvbox

### Variables
# Preferred apps
set $TERMINAL alacritty
set $BROWSER chromium
set $FILEMAN nemo
# Lock
set $locker swaylock --clock --fade-in 0.2 --image ~/.wallpapers/randall-mackey-mural2.jpg

### Sway Idle
exec swayidle -w \
    timeout 300 'swaylock --clock --fade-in 0.2 --image ~/.wallpapers/randall-mackey-mural2.jpg' \
    timeout 600 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep 'swaylock --clock --fade-in 0.2 --image ~/.wallpapers/randall-mackey-mural2.jpg'

# Dont idle on windows that are full screen
for_window [class="^.*"] inhibit_idle fullscreen
for_window [app_id="^.*"] inhibit_idle full

# Lock to black
set $lock swaylock --ignore-empty-password \
    --daemonize \
    --color 1d2021 \
    --show-keyboard-layout \
    --font Inconsolata \
    --text-color 282828 \
    --ring-color 689d6a \
    --ring-clear-color 98971a \
    --line-ver-color ebdbb2 \
    --line-uses-ring \

# Lock to black, stop sending output to monitor.
set $locksoff swayidle -w  \
    timeout 1 'swaylock -e -f -c 1d2021 -t' \
    timeout 2 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"; pkill -nx swayidle'

### Key bindings
#
# Include keybindings
include ~/.config/sway/bindings

# Quick floating terminal [ MOD + Shift + Return ]
for_window [app_id="Alacritty" title="Floating Terminal"] floating enable, show_marks no
set $qterm alacritty -t "Floating Terminal"
# start a quick floating terminal
bindsym $super+Shift+Return exec $qterm

bar {
	swaybar_command waybar
}

# Custom Window Treatment
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="firefox-wayland"] opacity 1
for_window [app_id="pamac-manager"] floating enable

### Input configuration
##
input "2:7:SynPS/2_Synaptics_TouchPad" {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
 }
#swaymsg -t get_inputs
