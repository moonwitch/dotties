{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window", "sway/mode"],
    "modules-right": ["idle_inhibitor", "pulseaudio", "network", "cpu", "memory", "battery", "temperature", "bluetooth", "backlight", "tray", "custom/worktime", "clock"],
    
    // MODULES LEFT
    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}: {icon}",
        //"format-icons": {
        //    "urgent": "яБк",
        //    "focused": "яЖТ",
        //    "default": "яДС"
        //}
    },

    // MODULES CENTER 
    "sway/window": {
        "format": "{}",
        "max-length": 50
    },

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    // MODULES RIGHT 
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },

    "network": {
        "format-wifi": "яЗл {essid}",
        "format-ethernet": "яГБ {ifname}: {ipaddr}",
        "format-disconnected": "Disconnected тЪа",
        "on-click": "alacritty -e nmtui",
        "tooltip": true,
    },

    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}яКФ {volume}%",
        "format-muted": "яАж",
        "format-icons": {
            "headphones": "яАе",
            "handsfree": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },

    "tray": {
        "icon-size": 20,
        "spacing": 10
    },

    "clock": {
        // Human Friendly
        "format-alt": " {:%A, %B %d at %I:%M %p}",
        // 24hr Robot Friendly
        "format": " {:%Y-%m-%d %H:%M}"
    },

    "cpu": {
        "interval": 5,
        "format": "яЛЫ {usage}%", // Icon: microchip
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click": "alacritty -e htop"
    },

    "memory": {
        "interval": 5,
        "format": "яФ╕ {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        },
        "on-click": "alacritty -e `free -h`"
    },

    "temperature": {
    "critical-threshold": 80,
    "interval": 5,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": [
        "яЛЛ", // Icon: temperature-empty
        "яЛК", // Icon: temperature-quarter
        "яЛЙ", // Icon: temperature-half
        "яЛИ", // Icon: temperature-three-quarters
        "яЛИ"  // Icon: temperature-full
    ],
    "tooltip": true
    },

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        // Connected to AC
        "format": "яГз {icon} {capacity}%", // Icon: bolt
        // Not connected to AC
        "format-discharging": "{icon} {capacity}%",
        "format-icons": [
            "яЙД", // Icon: battery-full
            "яЙГ", // Icon: battery-three-quarters
            "яЙВ", // Icon: battery-half
            "яЙБ", // Icon: battery-quarter
            "яЙА"  // Icon: battery-empty
        ],
        "tooltip": true,
        "tooltip-format": "{icon} {capacity}% {time}"
    },

    "backlight": {
        "interval": 5,
        "format": "{icon}",
        "format-alt": "{percent}% {icon}",
        "format-alt-click": "click-right",
        "format-icons": ["ЁЯМХ", "ЁЯМФ", "ЁЯМУ", "ЁЯМТ", "ЁЯМС"],
        "on-scroll-down": "brightnessctl -c backlight set +10%",
        "on-scroll-up": "brightnessctl -c backlight set 10%-"
    },

    "bluetooth": {
        "format": "{icon}",
        "format-alt": "BT:{status}",
        "interval": 30,
        "format-icons": {
        "enabled": "яКФ",
        "disabled": ""
        },
        "tooltip-format": "{status}"
    }
}

# vim:ft=json

